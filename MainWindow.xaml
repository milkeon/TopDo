<Window x:Class="TopDo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Top Do"
        Width="760"
        Height="920"
        MinWidth="620"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        LocationChanged="Window_StateChanged"
        SizeChanged="Window_StateChanged"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC" />
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#52FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#38FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MultilineFieldTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FieldTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Height" Value="96" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style x:Key="GlassActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#B57C3AED" Offset="0" />
                        <GradientStop Color="#B522D3EE" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#7AFFFFFF" />
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="28"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="10" Background="Transparent" ClipToBounds="True" PreviewMouseLeftButtonDown="WindowRoot_PreviewMouseLeftButtonDown">
        <Border CornerRadius="28"
                Background="#0CFFFFFF"
                BorderBrush="#66FFFFFF"
                BorderThickness="1.2"
                Padding="20"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="14" Opacity="0.28" Color="#020617" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Height="44" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="Top Do"
                               VerticalAlignment="Center"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,16,0,16"
                        Padding="18"
                        CornerRadius="22"
                        Background="#0FFFFFFF"
                        BorderBrush="#48FFFFFF"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.12" Color="#67E8F9" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="할 일" Foreground="#E2E8F0" Margin="0,0,0,6" />
                        <TextBox x:Name="TitleBox"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 KeyDown="TitleBox_KeyDown"
                                 GotKeyboardFocus="TitleBox_GotKeyboardFocus"
                                 PreviewMouseLeftButtonDown="TitleBox_PreviewMouseLeftButtonDown"
                                 ToolTip="할 일(타이틀)" />

                        <StackPanel x:Name="ComposerDetailsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                            <TextBlock Text="내용" Foreground="#E2E8F0" Margin="0,0,0,6" />
                            <TextBox x:Name="ContentBox"
                                     Style="{StaticResource MultilineFieldTextBoxStyle}"
                                     Height="92"
                                     ToolTip="내용" />

                            <TextBlock Text="할 일 목록" Foreground="#E2E8F0" Margin="0,12,0,6" />
                            <ItemsControl x:Name="ChecklistItemsControl"
                                          ItemsSource="{Binding ComposerChecklistItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0" />

                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FieldTextBoxStyle}"
                                                     Height="38"
                                                     HorizontalAlignment="Stretch"
                                                     PreviewKeyDown="ChecklistTextBox_PreviewKeyDown"
                                                     ToolTip="체크리스트 항목" />

                                            <Button Grid.Column="2"
                                                    Content="×"
                                                    Width="30"
                                                    Height="32"
                                                    Padding="0"
                                                    Margin="8,0,0,0"
                                                    Background="#14FFFFFF"
                                                    BorderBrush="#52FFFFFF"
                                                    BorderThickness="1"
                                                    Foreground="White"
                                                    Click="RemoveChecklistItem_Click"
                                                    Tag="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Enter로 항목 추가 · Shift+Enter로 완료"
                                       Foreground="#94A3B8"
                                       FontSize="11"
                                       Margin="0,6,0,0" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="날짜" Foreground="#E2E8F0" Margin="0,0,0,6" />
                                    <DatePicker x:Name="DueDatePicker"
                                                Height="40"
                                                Background="#14FFFFFF"
                                                BorderBrush="#38FFFFFF"
                                                BorderThickness="1"
                                                Foreground="White" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="시간" Foreground="#E2E8F0" Margin="0,0,0,6" />
                                    <TextBox x:Name="DueTimeBox"
                                             Style="{StaticResource FieldTextBoxStyle}"
                                             Text="09:00"
                                             ToolTip="시간(HH:mm)" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Button x:Name="ComposerActionButton"
                                Margin="0,14,0,0"
                                Content="추가"
                                Style="{StaticResource GlassActionButtonStyle}"
                                Click="ComposerActionButton_Click" />
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Items}"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="White"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="16"
                                    CornerRadius="18"
                                    HorizontalAlignment="Stretch"
                                    Background="#12FFFFFF"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#93C5FD" />
                                </Border.Effect>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Top" Margin="0,4,0,0" />
                                    <StackPanel Grid.Column="1" Margin="12,0,12,0" HorizontalAlignment="Stretch">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Content}"
                                                   FontSize="11"
                                                   Foreground="#E2E8F0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DueAt, StringFormat=마감: {0:yyyy-MM-dd HH:mm}}"
                                                   Foreground="#C7D2FE"
                                                   FontSize="11"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=생성: {0:yyyy-MM-dd HH:mm}}"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Content="삭제"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Width="72"
                                            Height="32"
                                            Padding="0"
                                            Click="DeleteButton_Click"
                                            Tag="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
